# Copia este archivo como ".env" y rellena tus datos reales.
# NUNCA subas el archivo ".env" real a GitHub ni lo compartas con nadie.

# Token de acceso de la API de WhatsApp (lo obtienes en Meta for Developers)
WHATSAPP_TOKEN=

# ID del número de teléfono de WhatsApp Business (lo obtienes en Meta for Developers)
WHATSAPP_PHONE_NUMBER_ID=

# Un "password" que tú inventas, se usa para verificar el webhook con Meta
VERIFY_TOKEN=mi_token_secreto_123

# Tu API Key de Claude (Anthropic) - la obtienes en console.anthropic.com
ANTHROPIC_API_KEY=

# Puerto del servidor (Render lo asigna automáticamente, no lo toques)
PORT=3000
